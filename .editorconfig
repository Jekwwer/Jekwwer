root = true

# NOTE: 'max_line_length' is a style guideline reference; not enforced by EditorConfig itself.

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
max_line_length = 88
trim_trailing_whitespace = true

# Lock files are auto-generated; preserve their content as-is
[*.lock]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{css,html,svg}]
max_line_length = 120

[*.{json,jsonc}]
max_line_length = 88

[*.md]
max_line_length = 120
trim_trailing_whitespace = false

[*.py]
indent_size = 4

[*.{txt,log}]
trim_trailing_whitespace = false
