{
  "name": "jekwwer/jekwwer",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/node:1.6.3": {
      "version": "22"
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": ["charliermarsh.ruff", "editorconfig.editorconfig", "esbenp.prettier-vscode", "jock.svg", "ms-python.debugpy", "ms-python.mypy", "ms-python.python", "ms-python.vscode-pylance", "streetsidesoftware.code-spell-checker"],
      "settings": {
        "[css]": {
          "editor.rulers": [120]
        },
        "[html]": {
          "editor.rulers": [120]
        },
        "[json][jsonc]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[markdown]": {
          "editor.rulers": [120]
        },
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        },
        "[svg]": {
          "editor.rulers": [120]
        },
        "[yaml]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "editor.formatOnPaste": true,
        "editor.formatOnSave": true,
        "editor.rulers": [88],
        "files.autoSave": "onFocusChange",
        "files.autoSaveWhenNoErrors": true,
        "prettier.configPath": "./.prettierrc",
        "prettier.prettierPath": "./node_modules/prettier",
        "python.terminal.activateEnvironment": false,
        "python.venvPath": "/home/vscode/.cache/pypoetry/virtualenvs"
      }
    }
  }
}
